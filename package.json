{
    "name": "advocato",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "vercel": "next build",
        "start": "next start",
        "lint": "eslint",
        "next:update": "bun add next@latest react@latest react-dom@latest eslint-config-next@latest",
        "commit": "git pull && bun update && bun getSecurity.js && bun run vercel && read -p 'Descriptions Commit: ' message && git add . && echo -n \"$message - \" && node getTime.js | xargs -I {} git commit -m \"$message - {}\" && git push",
        "clean": "rm -rf node_modules && bun install"
    },
    "dependencies": {
        "next": "16.2.3",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "styled-components": "^6.4.0"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "^10.2.0",
        "eslint-config-next": "16.2.3",
        "typescript": "^6.0.2"
    },
    "ignoreScripts": [
        "sharp",
        "unrs-resolver"
    ],
    "trustedDependencies": [
        "sharp",
        "unrs-resolver"
    ]
}
