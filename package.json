{
    "name": "advocato",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "vercel": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "commit": "git pull && bun update && bun getSecurity.js && bun run vercel && read -p 'Descriptions Commit: ' message && git add . && echo -n \"$message - \" && node getTime.js | xargs -I {} git commit -m \"$message - {}\" && git push",
        "clean": "rm -rf node_modules && bun install"
    },
    "dependencies": {
        "@types/express": "^5.0.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "sonner": "^2.0.7",
        "styled-components": "^6.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.5",
        "@types/node": "^24.13.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^9.39.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.64.0",
        "vite": "^8.1.4"
    }
}
